# Copy this file to `.aoe-team/telegram.env` and edit values.
# NEVER commit `.aoe-team/telegram.env` (it is gitignored).

# Required
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# Access control (comma-separated chat IDs)
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_ALLOW_CHAT_IDS=
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_READONLY_CHAT_IDS=

# Command prefix parsing. Recommended: prefer "!" but still accept "/".
# Examples:
# - AOE_TG_COMMAND_PREFIXES=!/   (preferred)
# - AOE_TG_COMMAND_PREFIXES=/!   (prefer "/" but accept "!")
AOE_TG_COMMAND_PREFIXES=!/

# Safety defaults
AOE_DENY_BY_DEFAULT=1
# AOE_OWNER_ONLY=1
# AOE_OWNER_BOOTSTRAP_MODE=dispatch

# Ephemeral "room" logs (Discord-like board). 0 disables GC (keep forever).
AOE_ROOM_RETENTION_DAYS=14
# Auto-post key TF lifecycle events into the current room (default: 1).
AOE_ROOM_AUTOPUBLISH=1
# Routing when current room is `global`: room | project | project-tf | tf
AOE_ROOM_AUTOPUBLISH_ROUTE=project

# TF exec cache TTL (worktree + run_dir) after success. 0 disables TTL cleanup.
# Note: if `AOE_TF_ARTIFACT_POLICY=all`, TTL is ignored.
AOE_TF_EXEC_CACHE_TTL_HOURS=72

# TF artifact policy: success-only (default) | all | none
# AOE_TF_ARTIFACT_POLICY=success-only
